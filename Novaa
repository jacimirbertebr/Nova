<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DropMaster OS - ERP & Loja</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.0.1/firebase-app.js";
        import { getFirestore, doc, setDoc, getDoc, collection, onSnapshot, addDoc, deleteDoc, updateDoc, query, orderBy } from "https://www.gstatic.com/firebasejs/11.0.1/firebase-firestore.js";
        import { getAuth, signInAnonymously, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/11.0.1/firebase-auth.js";

        // CONFIGURAÇÃO FIREBASE - SUBSTITUA PELOS SEUS DADOS AQUI
        const firebaseConfig = {
            apiKey: "SUA_API_KEY",
            authDomain: "SEU_PROJETO.firebaseapp.com",
            projectId: "SEU_PROJETO",
            storageBucket: "SEU_PROJETO.firebasestorage.app",
            messagingSenderId: "SEU_ID",
            appId: "SEU_APP_ID"
        };

        const app = initializeApp(firebaseConfig);
        const db = getFirestore(app);
        const auth = getAuth(app);
        const appId = 'dropmaster-ultra-v1';

        // Estado Global
        window.state = {
            user: null,
            products: [],
            finances: [],
            cart: [],
            settings: { columns: 'grid-cols-4', rounded: 'rounded-3xl', themeColor: 'blue' }
        };

        // --- AUTENTICAÇÃO E SINCRONIZAÇÃO ---
        onAuthStateChanged(auth, (user) => {
            if (user) {
                window.state.user = user;
                syncAllData();
            } else {
                signInAnonymously(auth);
            }
        });

        function syncAllData() {
            // Sincronizar Produtos
            onSnapshot(collection(db, 'products'), (snap) => {
                window.state.products = snap.docs.map(d => ({ id: d.id, ...d.data() }));
                renderStore();
                renderInventory();
                checkStockLevels();
                renderShoppingList();
            });

            // Sincronizar Finanças
            onSnapshot(collection(db, 'finances'), (snap) => {
                window.state.finances = snap.docs.map(d => d.data());
                calculateFinances();
            });
        }

        // --- FUNÇÕES DE ESCRITA NO FIREBASE ---
        window.saveProduct = async (p) => { await addDoc(collection(db, 'products'), p); };
        window.removeProduct = async (id) => { await deleteDoc(doc(db, 'products', id)); };
        
        window.checkout = async () => {
            if (window.state.cart.length === 0) return;
            showToast("Processando estoque...");
            let total = 0;
            for (const item of window.state.cart) {
                const ref = doc(db, 'products', item.id);
                const currentQty = (item.quantity || 0);
                if (currentQty > 0) await updateDoc(ref, { quantity: currentQty - 1 });
                total += parseFloat(item.price);
            }
            await addDoc(collection(db, 'finances'), { tipo: 'receita', valor: total, data: new Date().toISOString() });
            window.state.cart = [];
            updateCartUI();
            closeCart();
            showToast("Venda concluída!");
        };

        window.saveExpense = async (desc, val, cat) => {
            await addDoc(collection(db, 'finances'), { 
                tipo: 'despesa', descricao: desc, valor: parseFloat(val), categoria: cat, data: new Date().toISOString() 
            });
        };
    </script>

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap');
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .tab-content { display: none; }
        .tab-content.active { display: block; }
        .sidebar-item.active { background: #eff6ff; color: #2563eb; border-right: 4px solid #2563eb; }
    </style>
</head>
<body class="bg-slate-50 text-slate-900 min-h-screen">

    <div class="fixed bottom-6 right-6 z-[100] flex gap-2">
        <button onclick="changeContext('store')" class="bg-white border px-6 py-3 rounded-2xl shadow-xl font-bold flex items-center gap-2 hover:bg-slate-50 transition">
            <i data-lucide="shopping-bag" size="18"></i> Loja
        </button>
        <button onclick="changeContext('admin')" class="bg-slate-900 text-white px-6 py-3 rounded-2xl shadow-xl font-bold flex items-center gap-2 hover:scale-105 transition">
            <i data-lucide="layout-dashboard" size="18"></i> Admin
        </button>
    </div>

    <div id="toast" class="fixed top-6 right-6 z-[200] translate-x-[150%] transition-transform bg-white border p-4 rounded-2xl shadow-2xl flex items-center gap-3">
        <div class="p-2 bg-blue-100 text-blue-600 rounded-lg"><i data-lucide="bell" size="18"></i></div>
        <p id="toast-msg" class="text-sm font-bold"></p>
    </div>

    <div id="view-store">
        <header class="bg-white/80 backdrop-blur-md sticky top-0 z-50 border-b p-4">
            <div class="container mx-auto flex justify-between items-center">
                <div class="flex items-center gap-2 font-black text-xl"><div class="w-8 h-8 bg-blue-600 rounded-lg"></div> DropMaster</div>
                <button onclick="openCart()" class="relative p-3 bg-slate-100 rounded-xl">
                    <i data-lucide="shopping-cart"></i>
                    <span id="cart-badge" class="absolute -top-1 -right-1 bg-red-500 text-white text-[10px] w-5 h-5 rounded-full flex items-center justify-center">0</span>
                </button>
            </div>
        </header>
        <main class="container mx-auto px-6 py-12">
            <div id="store-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8"></div>
        </main>
    </div>

    <div id="view-admin" class="hidden flex">
        <aside class="w-64 border-r fixed h-full bg-white flex flex-col p-4">
            <h2 class="font-black text-xl mb-8 px-4">PAINEL OS</h2>
            <nav class="space-y-2">
                <button onclick="switchTab('dash')" id="btn-dash" class="sidebar-item active w-full flex items-center gap-3 p-4 rounded-xl font-bold text-sm transition">
                    <i data-lucide="pie-chart" size="18"></i> Métricas
                </button>
                <button onclick="switchTab('products')" id="btn-products" class="sidebar-item w-full flex items-center gap-3 p-4 rounded-xl font-bold text-sm text-slate-500 transition">
                    <i data-lucide="box" size="18"></i> Inventário
                </button>
            </nav>
        </aside>

        <main class="flex-1 ml-64 p-10">
            <div id="tab-dash" class="tab-content active space-y-8">
                <div id="stock-alerts" class="hidden bg-amber-50 border border-amber-200 p-6 rounded-3xl space-y-4">
                    <div class="flex items-center gap-2 text-amber-700 font-bold"><i data-lucide="alert-triangle"></i> Atenção: Itens em Falta</div>
                    <div id="alerts-list" class="grid grid-cols-2 gap-4"></div>
                </div>

                <div class="grid grid-cols-3 gap-6">
                    <div class="bg-white p-6 rounded-3xl border">
                        <p class="text-[10px] font-bold text-slate-400 uppercase">Receita Total</p>
                        <h4 id="report-income" class="text-3xl font-black text-emerald-600">R$ 0,00</h4>
                    </div>
                    <div class="bg-white p-6 rounded-3xl border">
                        <p class="text-[10px] font-bold text-slate-400 uppercase">Despesas</p>
                        <h4 id="report-expense" class="text-3xl font-black text-rose-600">R$ 0,00</h4>
                    </div>
                    <div class="bg-white p-6 rounded-3xl border bg-blue-50 border-blue-100">
                        <p class="text-[10px] font-bold text-blue-400 uppercase">Lucro Líquido</p>
                        <h4 id="report-profit" class="text-3xl font-black text-blue-700">R$ 0,00</h4>
                    </div>
                </div>
                
                <div class="bg-white p-6 rounded-3xl border flex justify-between items-center">
                    <div>
                        <h4 class="font-bold">Registrar Gasto</h4>
                        <p class="text-xs text-slate-400">Insira despesas fixas ou compras</p>
                    </div>
                    <button onclick="openExpenseModal()" class="bg-rose-500 text-white px-6 py-3 rounded-xl font-bold text-sm">Novo Gasto</button>
                </div>
            </div>

            <div id="tab-products" class="tab-content space-y-8">
                <div class="flex justify-between items-center">
                    <h3 class="text-2xl font-bold">Gestão de Dispensa</h3>
                    <button onclick="openProductModal()" class="bg-blue-600 text-white px-6 py-2 rounded-xl font-bold text-sm">Novo Produto</button>
                </div>
                <div class="bg-white rounded-3xl border overflow-hidden">
                    <table class="w-full text-left">
                        <thead class="bg-slate-50 text-[10px] font-bold text-slate-400 uppercase"><tr class="border-b"><th class="p-6">Item</th><th class="p-6">Estoque</th><th class="p-6">Preço</th><th class="p-6">Ação</th></tr></thead>
                        <tbody id="inventory-list" class="divide-y"></tbody>
                    </table>
                </div>

                <div class="bg-slate-900 p-8 rounded-[40px] text-white">
                    <div class="flex justify-between items-center mb-6">
                        <h4 class="text-xl font-bold">Lista de Reposição</h4>
                        <button onclick="sendToWhatsApp()" class="bg-emerald-500 px-6 py-3 rounded-2xl font-bold flex items-center gap-2 text-sm"><i data-lucide="message-circle" size="18"></i> Enviar WhatsApp</button>
                    </div>
                    <div id="shopping-list-container" class="grid gap-3"></div>
                </div>
            </div>
        </main>
    </div>

    <div id="modal-product" class="hidden fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-[150] flex items-center justify-center p-4">
        <div class="bg-white w-full max-w-md rounded-[32px] p-8 space-y-4">
            <h4 class="text-xl font-bold">Novo Produto</h4>
            <input type="text" id="new-p-name" placeholder="Nome" class="w-full bg-slate-100 p-4 rounded-2xl outline-none">
            <input type="number" id="new-p-price" placeholder="Preço R$" class="w-full bg-slate-100 p-4 rounded-2xl outline-none">
            <input type="number" id="new-p-qty" placeholder="Qtd. Inicial" class="w-full bg-slate-100 p-4 rounded-2xl outline-none">
            <button onclick="handleSaveProduct()" class="w-full bg-blue-600 text-white py-4 rounded-2xl font-bold">Cadastrar</button>
            <button onclick="closeModals()" class="w-full text-slate-400 text-sm font-bold">Cancelar</button>
        </div>
    </div>

    <div id="modal-expense" class="hidden fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-[150] flex items-center justify-center p-4">
        <div class="bg-white w-full max-w-md rounded-[32px] p-8 space-y-4">
            <h4 class="text-xl font-bold text-rose-600">Registrar Gasto</h4>
            <input type="text" id="exp-desc" placeholder="Descrição (Ex: Luz)" class="w-full bg-slate-100 p-4 rounded-2xl outline-none">
            <input type="number" id="exp-val" placeholder="Valor R$" class="w-full bg-slate-100 p-4 rounded-2xl outline-none">
            <button onclick="handleSaveExpense()" class="w-full bg-rose-500 text-white py-4 rounded-2xl font-bold">Confirmar Saída</button>
            <button onclick="closeModals()" class="w-full text-slate-400 text-sm font-bold">Cancelar</button>
        </div>
    </div>

    <div id="cart-drawer" class="fixed inset-y-0 right-0 w-full max-w-sm bg-white shadow-2xl z-[160] translate-x-full transition-transform flex flex-col">
        <div class="p-6 border-b flex justify-between items-center font-bold text-lg">Carrinho <button onclick="closeCart()"><i data-lucide="x"></i></button></div>
        <div id="cart-items" class="flex-1 overflow-y-auto p-6 space-y-4"></div>
        <div class="p-6 border-t space-y-4">
            <div class="flex justify-between font-black text-xl"><span>Total</span><span id="cart-total">R$ 0,00</span></div>
            <button onclick="checkout()" class="w-full bg-blue-600 text-white py-4 rounded-2xl font-bold">Finalizar Compra</button>
        </div>
    </div>

    <script>
        // --- INTERFACE E NAVEGAÇÃO ---
        function changeContext(ctx) {
            document.getElementById('view-store').classList.toggle('hidden', ctx === 'admin');
            document.getElementById('view-admin').classList.toggle('hidden', ctx === 'store');
            lucide.createIcons();
        }

        function switchTab(tab) {
            document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.sidebar-item').forEach(b => b.classList.remove('active'));
            document.getElementById(`tab-${tab}`).classList.add('active');
            document.getElementById(`btn-${tab}`).classList.add('active');
            lucide.createIcons();
        }

        function showToast(msg) {
            const t = document.getElementById('toast');
            document.getElementById('toast-msg').innerText = msg;
            t.classList.remove('translate-x-[150%]');
            setTimeout(() => t.classList.add('translate-x-[150%]'), 3000);
        }

        // --- RENDERIZAÇÃO ---
        function renderStore() {
            const grid = document.getElementById('store-grid');
            grid.innerHTML = window.state.products.map(p => `
                <div class="bg-white p-6 rounded-[32px] border hover:shadow-xl transition group">
                    <div class="h-40 bg-slate-50 rounded-2xl mb-4 flex items-center justify-center text-slate-300">
                        <i data-lucide="package" size="48"></i>
                    </div>
                    <h4 class="font-bold mb-1">${p.name}</h4>
                    <p class="text-[10px] text-slate-400 font-bold uppercase mb-4">${p.quantity || 0} em estoque</p>
                    <div class="flex justify-between items-center">
                        <span class="text-xl font-black">R$ ${parseFloat(p.price).toFixed(2)}</span>
                        <button onclick="addToCart('${p.id}')" class="bg-blue-600 text-white p-3 rounded-xl hover:scale-110 transition">
                            <i data-lucide="plus" size="18"></i>
                        </button>
                    </div>
                </div>
            `).join('');
            lucide.createIcons();
        }

        function renderInventory() {
            const list = document.getElementById('inventory-list');
            list.innerHTML = window.state.products.map(p => `
                <tr class="hover:bg-slate-50">
                    <td class="p-6 font-bold">${p.name}</td>
                    <td class="p-6"><span class="px-3 py-1 rounded-full text-xs font-bold ${p.quantity <= 3 ? 'bg-rose-100 text-rose-600' : 'bg-slate-100'}">${p.quantity || 0} unid</span></td>
                    <td class="p-6 font-bold text-slate-500">R$ ${p.price}</td>
                    <td class="p-6"><button onclick="window.removeProduct('${p.id}')" class="text-slate-300 hover:text-rose-500"><i data-lucide="trash-2" size="18"></i></button></td>
                </tr>
            `).join('');
            lucide.createIcons();
        }

        // --- FINANÇAS E ESTOQUE ---
        function calculateFinances() {
            let inc = 0, exp = 0;
            window.state.finances.forEach(f => {
                if(f.tipo === 'receita') inc += f.valor;
                else exp += f.valor;
            });
            document.getElementById('report-income').innerText = `R$ ${inc.toFixed(2)}`;
            document.getElementById('report-expense').innerText = `R$ ${exp.toFixed(2)}`;
            document.getElementById('report-profit').innerText = `R$ ${(inc - exp).toFixed(2)}`;
        }

        function checkStockLevels() {
            const low = window.state.products.filter(p => (p.quantity || 0) <= 3);
            const alertBox = document.getElementById('stock-alerts');
            if(low.length > 0) {
                alertBox.classList.remove('hidden');
                document.getElementById('alerts-list').innerHTML = low.map(p => `
                    <div class="bg-white p-3 rounded-xl border border-amber-200 text-xs font-bold text-amber-700">⚠️ ${p.name}: ${p.quantity || 0} restando</div>
                `).join('');
            } else alertBox.classList.add('hidden');
        }

        function renderShoppingList() {
            const low = window.state.products.filter(p => (p.quantity || 0) <= 3);
            const container = document.getElementById('shopping-list-container');
            if(low.length === 0) container.innerHTML = `<p class="text-slate-500 text-xs">Tudo abastecido!</p>`;
            else container.innerHTML = low.map(p => `<div class="bg-white/5 p-4 rounded-xl flex justify-between text-sm"><span>${p.name}</span><span class="text-rose-400 font-bold">Repor</span></div>`).join('');
        }

        // --- HANDLERS ---
        window.openProductModal = () => document.getElementById('modal-product').classList.remove('hidden');
        window.openExpenseModal = () => document.getElementById('modal-expense').classList.remove('hidden');
        window.closeModals = () => {
            document.getElementById('modal-product').classList.add('hidden');
            document.getElementById('modal-expense').classList.add('hidden');
        }

        window.handleSaveProduct = async () => {
            const name = document.getElementById('new-p-name').value;
            const price = document.getElementById('new-p-price').value;
            const quantity = parseInt(document.getElementById('new-p-qty').value);
            if(!name || !price) return;
            await window.saveProduct({ name, price, quantity, date: new Date().toISOString() });
            closeModals();
            showToast("Produto adicionado!");
        };

        window.handleSaveExpense = async () => {
            const desc = document.getElementById('exp-desc').value;
            const val = document.getElementById('exp-val').value;
            if(!desc || !val) return;
            await window.saveExpense(desc, val, 'geral');
            closeModals();
            showToast("Despesa registrada!");
        };

        window.sendToWhatsApp = () => {
            const low = window.state.products.filter(p => (p.quantity || 0) <= 3);
            if(low.length === 0) return;
            let msg = "*LISTA DE REPOSIÇÃO*%0A";
            low.forEach(p => msg += `• ${p.name} (Restam: ${p.quantity})%0A`);
            window.open(`https://wa.me/?text=${msg}`, '_blank');
        };

        // --- CARRINHO ---
        window.openCart = () => document.getElementById('cart-drawer').classList.remove('translate-x-full');
        window.closeCart = () => document.getElementById('cart-drawer').classList.add('translate-x-full');
        
        window.addToCart = (id) => {
            const p = window.state.products.find(x => x.id === id);
            window.state.cart.push(p);
            updateCartUI();
            showToast("No carrinho!");
        };

        function updateCartUI() {
            const cont = document.getElementById('cart-items');
            document.getElementById('cart-badge').innerText = window.state.cart.length;
            let tot = 0;
            cont.innerHTML = window.state.cart.map(i => {
                tot += parseFloat(i.price);
                return `<div class="p-4 bg-slate-50 rounded-xl flex justify-between font-bold text-xs"><span>${i.name}</span><span>R$ ${i.price}</span></div>`;
            }).join('');
            document.getElementById('cart-total').innerText = `R$ ${tot.toFixed(2)}`;
        }

        lucide.createIcons();
    </script>
</body>
</html>
